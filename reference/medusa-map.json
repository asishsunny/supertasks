      "Style": {
        "prop": "variant",
        "map": {
          "Primary": "primary",
          "Secondary": "secondary",
          "Danger": "danger",
          "Transparent": "transparent"
        }
      },
      "Size": {
        "prop": "size",
        "map": {
          "Small (28)": "small",
          "Base (32)": "base",
          "Large (40)": "large",
          "Xlarge (48)": "xlarge"
        }
      }
    }
  },
