{
  "Badge": {
    "tag": "Badge",
    "import": "@medusajs/ui",
    "textChild": "Badge",
    "variants": {
      "State": {
        "prop": "color",
        "map": {
          "Neutral": "grey",
          "Information": "blue",
          "Feature": "purple",
          "Success": "green",
          "Warning": "orange",
          "Error": "red"
        }
      }
    },
    "defaultProps": { "size": "small", "rounded": "full" }
  },
  "Status Badge": {
    "tag": "StatusBadge",
    "import": "@medusajs/ui",
    "textChild": "Badge",
    "variants": {
      "Status": {
        "prop": "color",
        "map": {
          "Neutral": "grey",
          "Information": "blue",
          "Feature": "purple",
          "Success": "green",
          "Warning": "orange",
          "Error": "red"
        }
      }
    }
  },
  "Avatar": {
    "tag": "_custom:avatar"
  },
  "Button": {
    "tag": "Button",
    "import": "@medusajs/ui",
    "textChild": "Label",
