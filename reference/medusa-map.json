          "Secondary": "secondary",
          "Transparent": "transparent",
          "Transparent Muted": "transparent"
        }
      },
      "Size": {
        "prop": "size",
        "map": {
          "Small (28)": "small",
          "Base (32)": "base",
          "Large (40)": "large"
        }
      }
    }
  },
  "Switch": {
